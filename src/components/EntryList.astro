---
import { entryHref, formatDate } from '../lib/content';
import { withBase } from '../lib/url';

const { entries } = Astro.props;
---

<div class="divide-y divide-zinc-800 border-y border-zinc-800">
  {entries.map((entry) => (
    <article class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
      <time class="text-sm text-zinc-500">{formatDate(entry.data.date)}</time>
      <div>
        <a class="text-base font-semibold text-zinc-100 hover:text-sky-300" href={withBase(entryHref(entry))}>
          {entry.data.title}
        </a>
        {entry.data.description && <p class="mt-1 text-sm leading-6 text-zinc-400">{entry.data.description}</p>}
        {entry.data.tags.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => <span class="text-xs text-zinc-500">#{tag}</span>)}
          </div>
        )}
      </div>
    </article>
  ))}
</div>
