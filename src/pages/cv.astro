---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';
---

<BaseLayout title="CV" description="Short CV and focus areas.">
  <section class="max-w-3xl">
    <p class="text-sm font-medium text-blue-700">CV</p>
    <h1 class="mt-3 text-4xl font-semibold">강건 — {site.role}</h1>
    <div class="mt-8 divide-y divide-zinc-200 border-y border-zinc-200">
      <section class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
        <h2 class="text-sm font-semibold text-zinc-500">Contact</h2>
        <p class="text-sm leading-6 text-zinc-700">
          <a class="text-blue-700" href="mailto:kangkk9714@gmail.com">kangkk9714@gmail.com</a> ·
          <a class="text-blue-700" href="https://github.com/KitchenGun">GitHub</a>
        </p>
      </section>
      <section class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
        <h2 class="text-sm font-semibold text-zinc-500">Experience</h2>
        <div class="space-y-3 text-sm leading-6 text-zinc-700">
          <p><strong>AIXLAB</strong> · Client Programmer · 2023.04 - Present</p>
          <p><strong>Ribbon Games</strong> · Unreal Client Programmer · 2022.10 - 2022.12</p>
        </div>
      </section>
      <section class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
        <h2 class="text-sm font-semibold text-zinc-500">Stack</h2>
        <p class="text-sm leading-6 text-zinc-700">
          C++, C#, Python, Verse, Unreal Engine 4/5, Unity, Behavior Tree, EQS, Common UI, Enhanced Input, Animation Blueprint, Sequencer, Steamworks, DLSS/FSR, Localization, Perforce, GitHub, SVN.
        </p>
      </section>
      <section class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
        <h2 class="text-sm font-semibold text-zinc-500">Projects</h2>
        <div class="space-y-3 text-sm leading-6 text-zinc-700">
          <p><strong>The Alley: Ghost Traces</strong> · challenge mode, puzzle logic, AI, UI, options, inventory, localization.</p>
          <p><strong>Forbidden Art</strong> · puzzle logic, input, inventory, Steam achievements, AI, localization, sound options.</p>
          <p><strong>UnrealMCP</strong> · natural-language Unreal workflow experiment.</p>
        </div>
      </section>
      <section class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
        <h2 class="text-sm font-semibold text-zinc-500">Awards</h2>
        <div class="space-y-2 text-sm leading-6 text-zinc-700">
          <p>2024 하반기 이달의 우수게임 — Forbidden Art.</p>
          <p>2025 Stove Indie Awards Top 10 — The Alley: Ghost Traces.</p>
          <p>대전스마트 콘텐츠 공모전, WSU 창업아이디어 경진대회, SGA 강철포폴 공모전 등.</p>
        </div>
      </section>
      <section class="grid gap-2 py-5 sm:grid-cols-[9rem_1fr]">
        <h2 class="text-sm font-semibold text-zinc-500">Education</h2>
        <p class="text-sm leading-6 text-zinc-700">우송대학교 게임 멀티미디어 공학사, 2016.03 - 2023.02.</p>
      </section>
    </div>
  </section>
</BaseLayout>
