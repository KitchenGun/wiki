---
import { getCollection, render } from 'astro:content';
import TagList from '../../components/TagList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { byDateDesc, entryHref, entrySlug, formatDate, isPublicEntry, relatedEntries } from '../../lib/content';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(isPublicEntry);
  return posts.map((entry) => ({ params: { slug: entrySlug(entry) }, props: { entry } }));
}

const { entry } = Astro.props;
const posts = (await getCollection('blog')).filter(isPublicEntry).sort(byDateDesc);
const related = relatedEntries(entry, posts);
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="mx-auto max-w-3xl">
    <a class="text-sm text-sky-400 hover:text-sky-300" href={withBase('/blog/')}>Blog</a>
    <h1 class="mt-3 text-4xl font-semibold leading-tight">{entry.data.title}</h1>
    <div class="mt-4 flex flex-col gap-3 text-sm text-zinc-500">
      <time>{formatDate(entry.data.date)}</time>
      <TagList tags={entry.data.tags} />
    </div>
    <div class="prose prose-zinc mt-8">
      <Content />
    </div>
  </article>

  {related.length > 0 && (
    <aside class="mx-auto mt-12 max-w-3xl border-t border-zinc-800 pt-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Related</h2>
      <ul class="mt-3 space-y-2">
        {related.map((item) => <li><a class="text-sky-400 hover:text-sky-300" href={withBase(entryHref(item))}>{item.data.title}</a></li>)}
      </ul>
    </aside>
  )}
</BaseLayout>
