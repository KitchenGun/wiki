---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { byDateDesc, isPublicEntry } from '../../lib/content';

const posts = (await getCollection('blog')).filter(isPublicEntry).sort(byDateDesc);
---

<BaseLayout title="Blog" description="Public development logs and essays.">
  <section>
    <p class="text-sm font-medium text-sky-400">Blog</p>
    <h1 class="mt-3 text-4xl font-semibold">Development logs and notes</h1>
    <div class="mt-8">
      <EntryList entries={posts} />
    </div>
  </section>
</BaseLayout>
