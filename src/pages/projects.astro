---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects" description="Selected projects and prototypes.">
  <section>
    <p class="text-sm font-medium text-blue-700">Projects</p>
    <h1 class="mt-3 text-4xl font-semibold">Selected work</h1>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {projects.map((project) => (
        <article class="border border-zinc-200 bg-white/45 p-5">
          <p class="text-xs font-medium uppercase text-zinc-500">{project.status}</p>
          <h2 class="mt-2 text-xl font-semibold">
            {project.href ? <a class="hover:text-blue-700" href={project.href}>{project.title}</a> : project.title}
          </h2>
          {(project.role || project.period) && (
            <p class="mt-1 text-xs text-zinc-500">{[project.role, project.period].filter(Boolean).join(' · ')}</p>
          )}
          <p class="mt-2 text-sm leading-6 text-zinc-600">{project.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {project.tags.map((tag) => <span class="text-xs text-zinc-500">#{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
