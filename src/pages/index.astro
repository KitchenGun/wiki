---
import { getCollection, render } from 'astro:content';
import EntryList from '../components/EntryList.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { byDateDesc, collectTags, isPublicEntry } from '../lib/content';
import { site } from '../lib/site';
import { withBase } from '../lib/url';

const posts = (await getCollection('blog')).filter(isPublicEntry).sort(byDateDesc);
const wiki = (await getCollection('wiki')).filter(isPublicEntry).sort(byDateDesc);
const home = (await getCollection('pages')).find((entry) => entry.id === 'home' && entry.data.visibility === 'public' && !entry.data.draft);
if (!home) throw new Error('Missing public page: home');
const topics = collectTags(wiki).slice(0, 10);
const { Content } = await render(home);
---

<BaseLayout title={site.title} description={home.data.description || site.description}>
  <section class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
    <div>
      <p class="text-sm font-medium text-sky-400">{home.data.eyebrow || `${site.role} / public notebook`}</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-semibold leading-tight text-zinc-50 sm:text-5xl">
        {home.data.heading ?? home.data.title}
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-zinc-400">
        {home.data.summary}
      </p>
    </div>

    <aside class="border-l border-zinc-800 pl-6">
      <img
        src={withBase('/profile.jpg')}
        alt={home.data.imageAlt || `${site.author} profile photo`}
        class="mb-6 aspect-[3/4] w-full max-w-xs object-cover object-[52%_45%]"
        decoding="async"
        loading="eager"
      />
      <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">About</h2>
      <div class="prose prose-zinc mt-3 text-sm leading-6 text-zinc-400">
        <Content />
      </div>
      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        {site.contacts.map((contact) => <a class="text-sky-400 hover:text-sky-300" href={contact.href}>{contact.label}</a>)}
      </div>
      <a class="mt-4 inline-block text-sm font-medium text-sky-400 hover:text-sky-300" href={withBase('/about/')}>Read more</a>
    </aside>
  </section>

  <section class="mt-14 grid gap-10 lg:grid-cols-[1fr_18rem]">
    <div>
      <div class="mb-4 flex items-end justify-between gap-4">
        <h2 class="text-xl font-semibold">Latest Posts</h2>
        <a class="text-sm text-sky-400 hover:text-sky-300" href={withBase('/blog/')}>All posts</a>
      </div>
      <EntryList entries={posts.slice(0, 3)} />
    </div>

    <div>
      <h2 class="text-xl font-semibold">Wiki Topics</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {topics.map((tag) => <a class="rounded-sm border border-zinc-700 bg-zinc-900/70 px-2 py-1 text-sm text-zinc-400 hover:border-sky-400 hover:text-sky-300" href={withBase('/wiki/')}>#{tag}</a>)}
      </div>
    </div>
  </section>

  <section class="mt-14">
    <div class="mb-4 flex items-end justify-between gap-4">
      <h2 class="text-xl font-semibold">Projects</h2>
      <a class="text-sm text-sky-400 hover:text-sky-300" href={withBase('/projects/')}>All projects</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {projects.slice(0, 3).map((project) => (
        <article class="border border-zinc-800 bg-zinc-900/70 p-4">
          <p class="text-xs font-medium uppercase text-zinc-500">{project.status}</p>
          <h3 class="mt-2 font-semibold">{project.title}</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">{project.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
