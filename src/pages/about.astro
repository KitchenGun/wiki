---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';
import { withBase } from '../lib/url';

const about = (await getCollection('pages')).find((entry) => entry.id === 'about' && entry.data.visibility === 'public' && !entry.data.draft);
if (!about) throw new Error('Missing public page: about');
const { Content } = await render(about);
const contacts = [...site.contacts, { label: 'YouTube', href: 'https://www.youtube.com/@kangkeon4500' }];
---

<BaseLayout title={about.data.title} description={about.data.description}>
  <section class="grid max-w-5xl gap-8 md:grid-cols-[18rem_1fr] md:items-start">
    <img
      src={withBase('/about-profile.jpg')}
      alt={about.data.imageAlt || about.data.heading || about.data.title}
      class="aspect-[3/4] w-full max-w-72 object-cover"
      decoding="async"
      loading="eager"
    />
    <div>
      <p class="text-sm font-medium text-sky-400">{about.data.eyebrow || about.data.title}</p>
      <h1 class="mt-3 text-4xl font-semibold">{about.data.heading ?? about.data.title}</h1>
      <div class="prose prose-zinc mt-8">
        <Content />
      </div>
      <div class="mt-6 flex flex-wrap gap-3 text-sm">
        {contacts.map((contact) => <a class="text-sky-400 hover:text-sky-300" href={contact.href}>{contact.label}</a>)}
      </div>
    </div>
  </section>
</BaseLayout>
