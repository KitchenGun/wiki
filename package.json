{
  "name": "personal-wiki",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run graph && astro dev",
    "content:check": "node scripts/check-public-content.mjs --strict-memory",
    "memory:ingest": "node scripts/memory-ingest.mjs",
    "memory:approve": "node scripts/memory-approve.mjs",
    "memory:decide": "node scripts/memory-decide.mjs",
    "memory:report": "node scripts/memory-report.mjs",
    "memory:github-watch": "node scripts/memory-github-watch.mjs",
    "memory:normalize": "node scripts/normalize-llm-frontmatter.mjs",
    "test:memory": "node scripts/test-memory-workflow.mjs",
    "graph": "node scripts/generate-graph-data.mjs",
    "graphify:update": "node scripts/graphify-update.mjs",
    "graphify:codex-semantics": "node scripts/graphify-codex-semantics.mjs",
    "graphify:extract": "graphify extract .",
    "graphify:benchmark": "graphify benchmark graphify-out/graph.json",
    "build": "npm run content:check && npm run graph && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.10",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "tailwindcss": "^4.2.4"
  }
}
